---
import BaseLayout from "./BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

interface Props {
  title: string;
  description: string;
  updated: string;
}
const { title, description, updated } = Astro.props;
---
<BaseLayout title={title} description={description} noindex>
  <Nav />
  <WhatsAppFab />
  <main class="relative pt-32 pb-20 md:pt-40">
    <div class="mx-auto max-w-3xl px-4">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Documento legal</p>
      <h1 class="font-display mt-3 text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">{title}</h1>
      <p class="mt-3 text-sm text-ink-500">Última actualización: {updated}</p>
      <div class="prose prose-neutral mt-10 max-w-none text-ink-800 [&_h2]:font-display [&_h2]:mt-10 [&_h2]:text-2xl [&_h2]:font-bold [&_h2]:text-ink-950 [&_h3]:font-display [&_h3]:mt-6 [&_h3]:text-lg [&_h3]:font-semibold [&_h3]:text-ink-950 [&_p]:mt-4 [&_p]:leading-relaxed [&_ul]:mt-3 [&_ul]:list-disc [&_ul]:pl-6 [&_li]:mt-1 [&_a]:text-brand-700 [&_a]:underline">
        <slot />
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
