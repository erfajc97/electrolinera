---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import SolarHero from "../components/solar/SolarHero.astro";
import SolarFeatures from "../components/solar/SolarFeatures.astro";
import SolarProjects from "../components/solar/SolarProjects.astro";
import SolarTech from "../components/solar/SolarTech.astro";
import Stats from "../components/Stats.astro";
import Proceso from "../components/Proceso.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

const meta = {
  title: "Paneles solares en Colombia · Energía fotovoltaica | Disart",
  description:
    "Paneles solares On-Grid, Off-Grid e híbridos en Colombia: utility scale, comercial, industrial y residencial. Más de 40 proyectos solares fotovoltaicos ejecutados por Disart Energy.",
  image: "/img/solar/solar-wind-farm.jpg",
  imageAlt: "Planta solar fotovoltaica utility scale instalada por Disart Energy en Colombia",
  keywords:
    "paneles solares Colombia, energía solar fotovoltaica Colombia, sistema solar residencial, sistema solar comercial, sistema solar industrial, utility scale solar Colombia, generación distribuida, AGPE Colombia, autogenerador pequeña escala",
};

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://disartenergy.com/solar/#service",
    serviceType: "Instalación de sistemas solares fotovoltaicos en Colombia",
    name: "Energía solar fotovoltaica On-Grid, Off-Grid e híbrida",
    provider: { "@id": "https://disartenergy.com/#org" },
    areaServed: { "@type": "Country", name: "Colombia" },
    audience: {
      "@type": "BusinessAudience",
      audienceType: "Empresas, industrias, constructoras, entidades públicas, comunidades energéticas",
    },
    description: meta.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: "https://disartenergy.com/" },
      { "@type": "ListItem", position: 2, name: "Energía solar", item: "https://disartenergy.com/solar" },
    ],
  },
];
---
<BaseLayout
  title={meta.title}
  description={meta.description}
  image={meta.image}
  imageAlt={meta.imageAlt}
  keywords={meta.keywords}
  jsonld={jsonld}
>
  <Nav />
  <WhatsAppFab />
  <main>
    <SolarHero />
    <SolarFeatures />
    <SolarProjects />
    <SolarTech />
    <Stats />
    <Proceso />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
