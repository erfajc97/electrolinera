---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import HomeHero from "../components/home/HomeHero.astro";
import TrustBar from "../components/TrustBar.astro";
import HomeServices from "../components/home/HomeServices.astro";
import HomeProjects from "../components/home/HomeProjects.astro";
import HomePurpose from "../components/home/HomePurpose.astro";
import HomeWhy from "../components/home/HomeWhy.astro";
import Proceso from "../components/Proceso.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

const meta = {
  title: "Disart Energy | Solar, EVs y electrolineras en Colombia",
  description:
    "Disart Energy: paneles solares, electrolineras DC fast charging e importación de vehículos eléctricos en Colombia. Ingeniería llave en mano y ROI medible.",
};
const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Disart Energy",
    url: "https://disartenergy.com",
    inLanguage: "es-CO",
    publisher: { "@type": "Organization", name: "Disart Energy" },
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://disartenergy.com/#org",
    name: "Disart Energy",
    image: "https://disartenergy.com/img/electrolinera/station-ev-fast.png",
    url: "https://disartenergy.com",
    telephone: "+573104836462",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bogotá",
      addressCountry: "CO",
    },
    areaServed: { "@type": "Country", name: "Colombia" },
    priceRange: "$$$",
  },
];
---
<BaseLayout title={meta.title} description={meta.description} jsonld={jsonld}>
  <Nav />
  <WhatsAppFab />
  <main>
    <HomeHero />
    <TrustBar />
    <HomeServices />
    <HomeProjects />
    <HomePurpose />
    <HomeWhy />
    <Proceso />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
