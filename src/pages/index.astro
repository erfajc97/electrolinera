---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import HomeHero from "../components/home/HomeHero.astro";
import TrustBar from "../components/TrustBar.astro";
import HomeServices from "../components/home/HomeServices.astro";
import HomeProjects from "../components/home/HomeProjects.astro";
import HomePurpose from "../components/home/HomePurpose.astro";
import HomeWhy from "../components/home/HomeWhy.astro";
import Proceso from "../components/Proceso.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

const meta = {
  title: "Electrolineras en Colombia · Franquicia 720 kW | Disart Energy",
  description:
    "Electrolineras DC fast charging, paneles solares e importación de vehículos eléctricos en Colombia. Franquicia 720 kW llave en mano con ROI desde 8.6 meses — Disart Energy.",
  image: "/img/electrolinera/charger-rain-suv.jpg",
  imageAlt: "Electrolinera Disart Energy en Bogotá Colombia con cargador DC fast charging cargando un SUV eléctrico",
  keywords:
    "electrolineras en Colombia, estación de carga eléctrica Colombia, carga rápida DC, franquicia electrolinera, paneles solares Colombia, energía solar fotovoltaica, importación vehículos eléctricos Colombia, movilidad eléctrica, Disart Energy",
};

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://disartenergy.com/#website",
    name: "Disart Energy",
    alternateName: "DISART Energy",
    url: "https://disartenergy.com",
    inLanguage: "es-CO",
    publisher: { "@id": "https://disartenergy.com/#org" },
    potentialAction: {
      "@type": "SearchAction",
      target: "https://disartenergy.com/?q={search_term_string}",
      "query-input": "required name=search_term_string",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://disartenergy.com/#webpage",
    url: "https://disartenergy.com/",
    name: meta.title,
    description: meta.description,
    inLanguage: "es-CO",
    isPartOf: { "@id": "https://disartenergy.com/#website" },
    about: { "@id": "https://disartenergy.com/#org" },
    primaryImageOfPage: { "@type": "ImageObject", url: "https://disartenergy.com" + meta.image },
  },
  {
    "@context": "https://schema.org",
    "@type": "ItemList",
    name: "Servicios Disart Energy",
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        url: "https://disartenergy.com/electrolineras",
        name: "Electrolineras de carga rápida DC en Colombia",
      },
      {
        "@type": "ListItem",
        position: 2,
        url: "https://disartenergy.com/inversion",
        name: "Inversión en franquicia de electrolinera 720 kW",
      },
      {
        "@type": "ListItem",
        position: 3,
        url: "https://disartenergy.com/movilidad",
        name: "Importación de vehículos eléctricos a Colombia",
      },
      {
        "@type": "ListItem",
        position: 4,
        url: "https://disartenergy.com/solar",
        name: "Paneles solares fotovoltaicos Colombia",
      },
    ],
  },
];
---
<BaseLayout
  title={meta.title}
  description={meta.description}
  image={meta.image}
  imageAlt={meta.imageAlt}
  keywords={meta.keywords}
  jsonld={jsonld}
>
  <Nav />
  <WhatsAppFab />
  <main>
    <HomeHero />
    <TrustBar />
    <HomeServices />
    <HomeProjects />
    <HomePurpose />
    <HomeWhy />
    <Proceso />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
