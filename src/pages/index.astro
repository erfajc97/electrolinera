---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import HomeHero from "../components/home/HomeHero.astro";
import TrustBar from "../components/TrustBar.astro";
import HomeServices from "../components/home/HomeServices.astro";
import HomeProjects from "../components/home/HomeProjects.astro";
import HomePurpose from "../components/home/HomePurpose.astro";
import HomeWhy from "../components/home/HomeWhy.astro";
import Proceso from "../components/Proceso.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

const meta = {
  title: "Disart Energy — Energía inteligente para un futuro sostenible",
  description:
    "Soluciones llave en mano de energía solar, movilidad eléctrica y electrolineras. Ingeniería, importación, instalación y operación en Colombia y Latinoamérica.",
};
const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Disart Energy",
    url: "https://disart.energy",
    inLanguage: "es-CO",
    publisher: { "@type": "Organization", name: "Disart Energy" },
  },
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "https://disart.energy/#org",
    name: "Disart Energy",
    image: "https://disart.energy/img/electrolinera/station-ev-fast.png",
    url: "https://disart.energy",
    telephone: "+573104836462",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Bogotá",
      addressCountry: "CO",
    },
    areaServed: { "@type": "Country", name: "Colombia" },
    priceRange: "$$$",
  },
];
---
<BaseLayout title={meta.title} description={meta.description} jsonld={jsonld}>
  <Nav />
  <WhatsAppFab />
  <main>
    <HomeHero />
    <TrustBar />
    <HomeServices />
    <HomeProjects />
    <HomePurpose />
    <HomeWhy />
    <Proceso />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
