---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import MovilidadHero from "../components/movilidad/MovilidadHero.astro";
import MovilidadShowroom from "../components/movilidad/MovilidadShowroom.astro";
import MovilidadFleet from "../components/movilidad/MovilidadFleet.astro";
import Stats from "../components/Stats.astro";
import CTA from "../components/CTA.astro";
import Footer from "../components/Footer.astro";
import WhatsAppFab from "../components/WhatsAppFab.astro";

const meta = {
  title: "Importación de vehículos eléctricos a Colombia | Disart Energy",
  description:
    "Importamos SUVs, sedanes y vehículos comerciales eléctricos directo de fábrica a Colombia. Nacionalización, matrícula, infraestructura de carga y flotas corporativas — Disart Energy.",
  image: "/img/vehiculos/toyota-white-front.jpg",
  imageAlt: "SUV eléctrico importado a Colombia por Disart Energy desde Shenzhen",
  keywords:
    "importación vehículos eléctricos Colombia, SUV eléctrico Colombia, Jetour Colombia, Toyota bZ Colombia, flota eléctrica corporativa, vehículo eléctrico empresa, carga rápida flota, movilidad eléctrica Colombia",
};

const jsonld = [
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "@id": "https://disartenergy.com/movilidad/#service",
    serviceType: "Importación y comercialización de vehículos eléctricos a Colombia",
    name: "Importación directa de vehículos eléctricos para Colombia",
    provider: { "@id": "https://disartenergy.com/#org" },
    areaServed: { "@type": "Country", name: "Colombia" },
    audience: {
      "@type": "BusinessAudience",
      audienceType: "Empresas con flotas, compradores corporativos, distribuidores",
    },
    description: meta.description,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Inicio", item: "https://disartenergy.com/" },
      { "@type": "ListItem", position: 2, name: "Movilidad eléctrica", item: "https://disartenergy.com/movilidad" },
    ],
  },
];
---
<BaseLayout
  title={meta.title}
  description={meta.description}
  image={meta.image}
  imageAlt={meta.imageAlt}
  keywords={meta.keywords}
  jsonld={jsonld}
>
  <Nav />
  <WhatsAppFab />
  <main>
    <MovilidadHero />
    <MovilidadShowroom />
    <MovilidadFleet />
    <Stats />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
