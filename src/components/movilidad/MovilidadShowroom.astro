---
const cars = [
  { img: "/img/vehiculos/toyota-white-front.jpg", brand: "Toyota", model: "bZ Crossover", color: "Blanco" },
  { img: "/img/vehiculos/toyota-silver-front.jpg", brand: "Toyota", model: "bZ Crossover", color: "Plata" },
  { img: "/img/vehiculos/toyota-black-port.jpg", brand: "Toyota", model: "bZ Crossover", color: "Negro" },
  { img: "/img/vehiculos/sedan-white-side.jpg", brand: "Toyota", model: "bZ Sedan", color: "Blanco" },
  { img: "/img/vehiculos/jetour-suv-black.jpg", brand: "Jetour", model: "T1 / T2 SUV", color: "Negro" },
];
---
<section id="showroom" class="relative bg-gradient-to-b from-white to-brand-50/40 py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-end gap-10 md:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Showroom · Shenzhen</p>
        <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
          Vehículos disponibles ahora.
        </h2>
      </div>
      <p class="text-lg text-ink-700">
        Negociamos directo con los fabricantes y consolidamos en nuestro centro
        de despacho. Color, autonomía y configuración a tu elección.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <!-- Featured large card -->
      <article class="group relative overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-soft transition hover:-translate-y-1 hover:border-brand-200 lg:col-span-2 lg:row-span-2">
        <div class="relative h-full min-h-[420px]">
          <img src={cars[0].img} alt={cars[0].model} class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950/80 via-ink-950/20"></div>
          <div class="absolute inset-x-6 bottom-6 flex items-end justify-between gap-4 text-white">
            <div>
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Centro de entregas · Shenzhen</p>
              <p class="font-display mt-1 text-2xl font-bold">{cars[0].brand} {cars[0].model}</p>
              <p class="text-sm text-ink-200">Disponible en blanco, plata y negro · Entrega 60–90 días</p>
            </div>
            <a href="/#contacto" class="hidden shrink-0 rounded-full bg-lime-glow px-4 py-2 text-xs font-bold text-ink-950 transition hover:bg-white sm:inline-flex">Cotizar</a>
          </div>
        </div>
      </article>

      {cars.slice(1).map((c) => (
        <article class="group overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-soft transition hover:-translate-y-1 hover:border-brand-200">
          <div class="relative aspect-[4/3] overflow-hidden">
            <img src={c.img} alt={`${c.brand} ${c.model} — ${c.color}`} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" />
            <span class="absolute right-3 top-3 rounded-full bg-white/90 px-2 py-0.5 text-[10px] font-bold text-brand-700 backdrop-blur">{c.color}</span>
          </div>
          <div class="p-4">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">{c.brand}</p>
            <p class="font-display text-sm font-bold text-ink-950">{c.model}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
