---
---
<section id="contacto" class="relative px-4 py-24">
  <div class="relative mx-auto max-w-6xl overflow-hidden rounded-[2.5rem] border border-brand-700/30 bg-ink-950 p-10 text-white shadow-glow md:p-16">
    <div class="absolute inset-0 -z-0 opacity-60 [background-image:radial-gradient(60%_60%_at_100%_0%,oklch(0.55_0.17_152_/_0.6),transparent_60%),radial-gradient(40%_60%_at_0%_100%,oklch(0.88_0.20_130_/_0.4),transparent_60%)]"></div>
    <div class="absolute inset-0 -z-0 opacity-30 bg-grid"></div>

    <div class="relative grid items-center gap-10 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-200">Da el siguiente paso</p>
        <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight md:text-6xl">
          ¿Listo para electrificar tu negocio?
        </h2>
        <p class="mt-4 max-w-xl text-pretty text-lg text-ink-300">
          Te entregamos un diagnóstico gratuito en 48 horas. Sin compromiso.
          Si tu sitio califica, te enviamos una propuesta cerrada con ROI estimado.
        </p>

        <ul class="mt-6 grid grid-cols-2 gap-2 text-sm text-ink-200 max-w-md">
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-lime-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Sin costo</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-lime-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>48 horas</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-lime-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Confidencial</li>
          <li class="flex items-center gap-2"><svg class="h-4 w-4 text-lime-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>Cobertura nacional</li>
        </ul>
      </div>

      <form id="contact-form" class="lg:col-span-5 rounded-3xl border border-white/10 bg-white/5 p-6 backdrop-blur" novalidate>
        <div class="space-y-4">
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-200">Nombre</span>
            <input name="name" required type="text" maxlength="120" autocomplete="name" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-ink-300 outline-none transition focus:border-brand-400" placeholder="Harold Velázquez"/>
          </label>
          <div class="grid gap-4 sm:grid-cols-2">
            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-brand-200">Email</span>
              <input name="email" required type="email" maxlength="200" autocomplete="email" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-ink-300 outline-none transition focus:border-brand-400" placeholder="harold@empresa.co"/>
            </label>
            <label class="block">
              <span class="text-xs font-semibold uppercase tracking-widest text-brand-200">Teléfono</span>
              <input name="phone" required type="tel" inputmode="tel" maxlength="30" pattern="^\+?[0-9\s()\-]{7,20}$" autocomplete="tel" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-ink-300 outline-none transition focus:border-brand-400" placeholder="+57 300 000 0000"/>
            </label>
          </div>
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-200">Ciudad / sitio</span>
            <input name="city" required type="text" maxlength="120" autocomplete="address-level2" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white placeholder-ink-300 outline-none transition focus:border-brand-400" placeholder="Bogotá, Chapinero"/>
          </label>
          <label class="block">
            <span class="text-xs font-semibold uppercase tracking-widest text-brand-200">¿Qué te interesa?</span>
            <select name="interest" class="mt-1.5 w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm text-white outline-none transition focus:border-brand-400">
              <option class="bg-ink-900">Franquicia llave en mano</option>
              <option class="bg-ink-900">Hardware (compra directa)</option>
              <option class="bg-ink-900">Solar + electrolinera</option>
              <option class="bg-ink-900">Solo software / dashboard</option>
            </select>
          </label>

          <!-- Honeypot — hidden from real users, bots will fill it. -->
          <label class="absolute left-[-9999px] top-[-9999px]" aria-hidden="true" tabindex="-1">
            Sitio web
            <input name="website" type="text" tabindex="-1" autocomplete="off"/>
          </label>

          <button type="submit" data-submit class="group inline-flex w-full items-center justify-center gap-2 rounded-full bg-lime-glow px-5 py-3.5 text-sm font-bold text-ink-950 transition hover:bg-white disabled:cursor-not-allowed disabled:opacity-60">
            <span data-label>Solicitar diagnóstico</span>
            <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </button>

          <p data-feedback class="hidden rounded-xl border border-lime-glow/40 bg-lime-glow/10 px-3 py-2 text-center text-xs text-lime-glow"></p>

          <p class="text-center text-[10px] text-ink-400">Al enviar aceptas la política de privacidad de Disart Energy.</p>
        </div>
      </form>

      <script>
        const form = document.getElementById('contact-form') as HTMLFormElement | null;
        if (form) {
          const button = form.querySelector('[data-submit]') as HTMLButtonElement;
          const label = form.querySelector('[data-label]') as HTMLSpanElement;
          const feedback = form.querySelector('[data-feedback]') as HTMLParagraphElement;
          const originalLabel = label.textContent ?? 'Solicitar diagnóstico';

          form.addEventListener('submit', async (event) => {
            event.preventDefault();

            const data = new FormData(form);
            const payload = {
              name: String(data.get('name') ?? '').slice(0, 120),
              email: String(data.get('email') ?? '').slice(0, 200),
              phone: String(data.get('phone') ?? '').slice(0, 30),
              city: String(data.get('city') ?? '').slice(0, 120),
              interest: String(data.get('interest') ?? '').slice(0, 120),
              website: String(data.get('website') ?? '').slice(0, 200),
            };

            button.disabled = true;
            label.textContent = 'Enviando…';
            feedback.classList.add('hidden');

            try {
              const res = await fetch('/api/contact', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload),
              });
              const body = await res.json().catch(() => ({}));

              if (res.ok && body.ok) {
                feedback.textContent = '¡Listo, Harold! Te contactamos en menos de 24 horas.';
                feedback.classList.remove('hidden', 'border-red-400/40', 'bg-red-500/10', 'text-red-200');
                feedback.classList.add('border-lime-glow/40', 'bg-lime-glow/10', 'text-lime-glow');
                form.reset();
              } else {
                throw new Error(body.error ?? 'NETWORK');
              }
            } catch {
              feedback.textContent = 'No se pudo enviar. Intenta de nuevo o escríbenos a hola@disart.energy.';
              feedback.classList.remove('hidden', 'border-lime-glow/40', 'bg-lime-glow/10', 'text-lime-glow');
              feedback.classList.add('border-red-400/40', 'bg-red-500/10', 'text-red-200');
            } finally {
              button.disabled = false;
              label.textContent = originalLabel;
            }
          });
        }
      </script>
    </div>
  </div>
</section>
