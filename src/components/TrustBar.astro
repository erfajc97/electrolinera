---
const items = [
  "Hardware certificado IEC 61851",
  "OCPP 1.6 / 2.0.1",
  "Pagos integrados",
  "Roaming nacional",
  "Soporte 24/7",
  "Energía 100% limpia",
];
---
<section class="border-y border-ink-100 bg-white/60 py-6 backdrop-blur">
  <div class="mx-auto max-w-6xl overflow-hidden px-4">
    <div class="flex w-max gap-10 animate-marquee will-change-transform">
      {[...items, ...items].map((t) => (
        <div class="flex shrink-0 items-center gap-2 text-sm font-medium text-ink-700">
          <svg class="h-4 w-4 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
          {t}
        </div>
      ))}
    </div>
  </div>
</section>
