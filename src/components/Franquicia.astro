---
const bullets = [
  { k: "Llave en mano",       v: "Cargadores, transformador, obra civil, sistema eléctrico, permisos y legalización — todo incluido." },
  { k: "Importación exenta",  v: "No te retiene aduana. Somos importadores certificados con todos los permisos en Colombia." },
  { k: "Modelo escalable",    v: "Comienza con 1 estación de 720 kW y crece a una red multi-sitio bajo la misma plataforma." },
  { k: "Operación sin fricción", v: "Hardware, software, mantenimiento y soporte 24/7 corren por nuestra cuenta — tú recibes utilidades." },
];

const shares = [
  { usd: "USD 19.000",  pct: "10%",  ret: "≈ USD 1.800/mes",  highlight: false },
  { usd: "USD 38.000",  pct: "20%",  ret: "≈ USD 3.600/mes",  highlight: false },
  { usd: "USD 57.000",  pct: "30%",  ret: "≈ USD 5.400/mes",  highlight: false },
  { usd: "USD 95.000",  pct: "50%",  ret: "≈ USD 9.000/mes",  highlight: true  },
  { usd: "USD 190.000", pct: "100%", ret: "≈ USD 18.000/mes", highlight: false },
];
---
<section id="franquicia" class="relative overflow-hidden bg-linear-to-b from-ink-50 to-white py-16 md:py-24">
  <div class="absolute inset-x-0 top-0 -z-10 h-64 bg-radial-fade opacity-60"></div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-end gap-10 md:grid-cols-2">
      <div>
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Modelo de franquicia</p>
        <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
          Una franquicia. 720 kW. Cero engorros.
        </h2>
      </div>
      <p class="text-lg text-ink-700">
        Cada electrolinera Disart está compuesta por <strong>3 cargadores de 240 kW</strong>
        (6 mangueras simultáneas, 600 kWh/h instalados). Aportas el capital, nosotros
        entregamos el activo en operación y la gestión continua.
      </p>
    </div>

    <div class="mt-12 grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <div class="relative overflow-hidden rounded-4xl border border-ink-100 shadow-soft">
          <img src="/img/electrolinera/station-ev-fast.png" alt="Cargador EV-FAST en sitio" class="h-full w-full object-cover" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-linear-to-t from-ink-950/65 via-transparent"></div>
          <div class="absolute bottom-5 left-5 right-5 flex items-center gap-3 text-white">
            <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-500/90 backdrop-blur">
              <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor"><path d="M14.69 2.66 9.5 12h4l-1.19 9.34L18 12h-4l1.19-9.34Z"/></svg>
            </span>
            <div>
              <p class="text-xs font-medium uppercase tracking-widest text-brand-200">Cargador instalado</p>
              <p class="font-display text-base font-semibold">DISART YLC-KC-240 · CCS2 × 2</p>
            </div>
          </div>
        </div>

        <ul class="mt-8 space-y-4">
          {bullets.map((b) => (
            <li class="flex items-start gap-3 rounded-2xl border border-ink-100 bg-white p-4 shadow-soft">
              <span class="mt-0.5 grid h-7 w-7 shrink-0 place-items-center rounded-full bg-brand-100 text-brand-700">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              </span>
              <div>
                <p class="text-sm font-semibold text-ink-950">{b.k}</p>
                <p class="text-sm text-ink-700">{b.v}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>

      <div class="lg:col-span-7">
        <div class="rounded-3xl border border-ink-100 bg-white p-6 shadow-soft md:p-8">
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Participación accionaria</p>
              <h3 class="font-display mt-1 text-2xl font-bold text-ink-950">Tabla de participación</h3>
              <p class="mt-1 text-sm text-ink-700">Cada inversionista adquiere un porcentaje de la electrolinera y de sus utilidades.</p>
            </div>
            <span class="hidden rounded-full bg-brand-50 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-700 ring-1 ring-inset ring-brand-200 sm:inline-flex">Escenario objetivo · 6 h/día</span>
          </div>

          <div class="mt-6 overflow-hidden rounded-2xl border border-ink-100">
            <table class="w-full text-left text-sm">
              <thead class="bg-ink-50">
                <tr>
                  <th class="px-4 py-3 text-[11px] font-semibold uppercase tracking-wider text-ink-500">Inversión</th>
                  <th class="px-4 py-3 text-[11px] font-semibold uppercase tracking-wider text-ink-500">Participación</th>
                  <th class="px-4 py-3 text-[11px] font-semibold uppercase tracking-wider text-ink-500">Retorno mensual</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-ink-100 bg-white">
                {shares.map((s) => (
                  <tr class={s.highlight ? "bg-brand-50/50" : ""}>
                    <td class="px-4 py-3 font-display text-base font-bold text-ink-950">{s.usd}</td>
                    <td class="px-4 py-3 font-semibold text-ink-700">
                      {s.pct}
                      {s.highlight && <span class="ml-2 rounded-full bg-brand-600 px-2 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white">recomendado</span>}
                    </td>
                    <td class="px-4 py-3 font-medium text-brand-700">{s.ret}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>

          <p class="mt-3 text-xs text-ink-500">
            Retornos proyectados sobre facturación mínima estimada de USD 18.000/mes
            (escenario objetivo). Valores antes de costos operativos y fiscales.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/inversion" class="group inline-flex items-center gap-1.5 rounded-full bg-ink-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700">
              Calcular mi retorno
              <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href="#contacto" class="inline-flex items-center gap-1.5 rounded-full border border-ink-300 bg-white px-5 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-400 hover:text-brand-700">
              Agendar diagnóstico
            </a>
          </div>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-3">
          <div class="rounded-2xl border border-ink-100 bg-white p-5 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Escenario bajo · 3 h/día</p>
            <p class="font-display mt-2 text-xl font-bold text-ink-950">20 meses</p>
            <p class="mt-1 text-xs text-ink-500">payback proyectado</p>
          </div>
          <div class="rounded-2xl border border-brand-200 bg-brand-50/50 p-5 shadow-soft ring-1 ring-inset ring-brand-200">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Objetivo · 6 h/día</p>
            <p class="font-display mt-2 text-xl font-bold text-ink-950">8.6 meses</p>
            <p class="mt-1 text-xs text-ink-500">payback proyectado</p>
          </div>
          <div class="rounded-2xl border border-ink-100 bg-white p-5 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Alto · 9 h/día</p>
            <p class="font-display mt-2 text-xl font-bold text-ink-950">5.5 meses</p>
            <p class="mt-1 text-xs text-ink-500">payback proyectado</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
