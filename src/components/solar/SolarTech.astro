---
---
<section class="relative py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Tecnología que instalamos</p>
      <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
        Hardware certificado, software de monitoreo, baterías de litio.
      </h2>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      <article class="overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-soft">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/img/solar/inverter-cabinet.jpg" alt="Inversor fotovoltaico DC-AC" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Inversores fotovoltaicos</p>
          <h3 class="font-display mt-2 text-xl font-bold text-ink-950">Conversión DC → AC industrial</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-700">
            Gabinetes con inversores certificados, protecciones eléctricas y arquitectura
            para mantenimiento sin paradas. Compatible con string y centralizada.
          </p>
        </div>
      </article>

      <article class="overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-soft">
        <div class="aspect-[4/3] overflow-hidden">
          <img src="/img/solar/offgrid-battery.jpg" alt="Almacenamiento off-grid" class="h-full w-full object-cover" loading="lazy" />
        </div>
        <div class="p-6">
          <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Almacenamiento off-grid</p>
          <h3 class="font-display mt-2 text-xl font-bold text-ink-950">Banco de baterías de litio</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-700">
            Sistemas autónomos para zonas no interconectadas o respaldo total.
            BMS inteligente, ciclos garantizados y monitoreo remoto incluido.
          </p>
        </div>
      </article>
    </div>

    <div class="mt-10 grid gap-4 rounded-3xl border border-ink-100 bg-ink-950 p-6 text-white sm:grid-cols-3">
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-500"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 13h2l3-9 4 18 3-9h6"/></svg></span>
        <div><p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Monitoreo en vivo</p><p class="font-display text-sm font-bold">Producción + alertas</p></div>
      </div>
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-500"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M20 6 9 17l-5-5"/></svg></span>
        <div><p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Certificación</p><p class="font-display text-sm font-bold">RETIE + IEC</p></div>
      </div>
      <div class="flex items-center gap-3">
        <span class="grid h-10 w-10 place-items-center rounded-xl bg-brand-500"><svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg></span>
        <div><p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Garantía</p><p class="font-display text-sm font-bold">25 años módulos</p></div>
      </div>
    </div>
  </div>
</section>
