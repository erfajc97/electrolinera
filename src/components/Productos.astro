---
const specs = [
  { k: "Potencia nominal", v: "240 kW" },
  { k: "Conectores",        v: "CCS2 × 2" },
  { k: "Cable",             v: "5 m" },
  { k: "Tensión salida",    v: "200–1000 V (potencia constante)" },
  { k: "Corriente salida",  v: "0–250 A" },
  { k: "Eficiencia",        v: "≥ 94.5%" },
  { k: "Refrigeración",     v: "Aire forzado" },
  { k: "Comunicación",      v: "Ethernet · 2/3/4G · OCPP 1.6" },
  { k: "Pago",              v: "Tarjeta + lectura de código" },
  { k: "Estándares",        v: "IEC 61851-1, IEC 61851-23, EN 61851-24" },
];
---
<section id="productos" class="relative bg-white py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="flex flex-wrap items-end justify-between gap-6">
      <div class="max-w-xl">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Hardware</p>
        <h2 class="font-display mt-3 text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
          Cargador DISART YLC-KC-240
        </h2>
      </div>
      <p class="max-w-md text-ink-700">
        El cargador insignia de nuestra franquicia. Tres unidades por estación,
        importadas, certificadas e integradas al ecosistema Disart.
      </p>
    </div>

    <div class="mt-12 grid gap-6 overflow-hidden rounded-6xl border border-ink-100 bg-white shadow-soft lg:grid-cols-12">
      <div class="relative overflow-hidden bg-linear-to-br from-ink-50 to-brand-50/40 p-4 sm:p-6 lg:col-span-5 lg:p-6">
        <div class="relative aspect-16/9 overflow-hidden rounded-4xl shadow-soft ring-1 ring-ink-100 lg:aspect-auto lg:h-full lg:min-h-[18rem]">
          <img src="/img/electrolinera/electrolinerasdisart.jpg" alt="Electrolinera Disart Energy con 3 cargadores DC fast charging YLC-KC-240 de 240 kW operando en Colombia" class="absolute inset-0 h-full w-full object-cover object-center" loading="lazy" decoding="async" />
          <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-brand-600 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white shadow-soft">
            Marca DISART
          </span>
          <span class="absolute bottom-4 left-4 inline-flex items-center gap-1.5 rounded-full bg-ink-950/85 px-3 py-1.5 text-[10px] font-bold uppercase tracking-widest text-white shadow-soft backdrop-blur">
            <span class="h-1.5 w-1.5 rounded-full bg-lime-glow animate-pulse-soft"></span>
            En operación · 3 × 240 kW
          </span>
        </div>
      </div>

      <div class="flex flex-col p-8 lg:col-span-7 lg:p-10">
        <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Especificación técnica</p>
        <h3 class="font-display mt-2 text-3xl font-bold text-ink-950">YLC-KC-240 · 240 kW DC</h3>
        <p class="mt-3 text-sm text-ink-700">
          Carga ultra rápida con doble pistola CCS2. Modular, escalable y compatible
          con OCPP 1.6 para integración con cualquier CPMS. Cada franquicia instala
          tres unidades, sumando 720 kW de potencia y 6 conectores simultáneos.
        </p>

        <dl class="mt-6 grid grid-cols-1 gap-x-6 gap-y-3 sm:grid-cols-2">
          {specs.map((s) => (
            <div class="flex items-baseline justify-between gap-3 border-b border-dashed border-ink-100 py-1.5">
              <dt class="text-xs font-medium text-ink-500">{s.k}</dt>
              <dd class="text-sm font-semibold text-ink-950 text-right">{s.v}</dd>
            </div>
          ))}
        </dl>

        <div class="mt-8 flex flex-wrap gap-2.5">
          <a href="/inversion" class="inline-flex items-center gap-1.5 rounded-full bg-ink-950 px-5 py-3 text-sm font-semibold text-white transition hover:bg-brand-700">
            Invertir en una estación
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#contacto" class="inline-flex items-center gap-1.5 rounded-full border border-ink-300 px-5 py-3 text-sm font-semibold text-ink-900 transition hover:border-brand-400 hover:text-brand-700">
            Pedir ficha técnica
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
