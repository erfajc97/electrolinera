---
---
<section id="top" class="relative isolate overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="absolute inset-0 -z-10 bg-radial-fade"></div>
  <div class="absolute inset-0 -z-10 bg-grid"></div>
  <div class="absolute inset-0 -z-10 bg-grid-beam"></div>

  <!-- Floating energy particles drifting up through the grid -->
  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <span class="hero-spark" style="--x:8%;  --d:0s;   --dur:9s;"></span>
    <span class="hero-spark" style="--x:22%; --d:1.4s; --dur:11s;"></span>
    <span class="hero-spark" style="--x:35%; --d:3.2s; --dur:8s;"></span>
    <span class="hero-spark" style="--x:48%; --d:0.6s; --dur:13s;"></span>
    <span class="hero-spark" style="--x:62%; --d:2.1s; --dur:10s;"></span>
    <span class="hero-spark" style="--x:75%; --d:4s;   --dur:12s;"></span>
    <span class="hero-spark" style="--x:88%; --d:1.8s; --dur:9.5s;"></span>
  </div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <a href="#franquicia" class="group inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white/70 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 backdrop-blur">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-brand-500 text-[10px] text-white">★</span>
          Franquicia abierta · cupos limitados
          <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <h1 class="font-display mt-6 text-balance text-5xl font-bold leading-[1.02] tracking-tight text-ink-950 md:text-6xl lg:text-7xl">
          La red de
          <span class="relative whitespace-nowrap">
            <span class="bg-gradient-to-r from-brand-600 via-brand-500 to-brand-700 bg-clip-text text-transparent">electrolineras</span>
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12" fill="none" aria-hidden>
              <path d="M2 9 C 80 2, 160 2, 298 9" stroke="oklch(0.64 0.18 152)" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
          que impulsa tu negocio.
        </h1>

        <p class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-ink-700">
          Desde Colombia para Colombia. Disart Energy lleva la energía limpia un paso
          más allá: operamos franquicias de electrolineras llave en mano con hardware
          certificado, app para conductores y dashboard de gestión en tiempo real.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="#contacto" class="group inline-flex items-center gap-2 rounded-full bg-brand-600 px-6 py-3.5 text-sm font-semibold text-white shadow-glow transition hover:bg-brand-700">
            Solicitar mi franquicia
            <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#tecnologia" class="inline-flex items-center gap-2 rounded-full border border-ink-300 bg-white/60 px-6 py-3.5 text-sm font-semibold text-ink-900 backdrop-blur transition hover:border-brand-400 hover:text-brand-700">
            Ver tecnología
          </a>
        </div>

        <dl class="mt-12 grid max-w-md grid-cols-3 gap-6">
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Cargas/mes</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">+2.4k</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Uptime</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">99.7%</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">CO₂ evitado</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-brand-600">↓ 38 t</dd>
          </div>
        </dl>
      </div>

      <div class="relative lg:col-span-5">
        <div class="relative mx-auto aspect-[3/4] max-w-md">
          <div class="absolute -inset-6 rounded-[2rem] bg-gradient-to-br from-brand-200/60 to-lime-glow/40 blur-2xl"></div>
          <div class="relative h-full overflow-hidden rounded-[2rem] border border-white/60 shadow-glow">
            <img src="/img/electrolinera/charger-rain-suv.jpg" alt="Electrolinera Disart Energy en operación" class="h-full w-full object-cover" loading="eager" fetchpriority="high" />
            <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-ink-950/80 to-transparent"></div>
            <div class="absolute bottom-5 left-5 right-5 flex items-center justify-between">
              <div class="text-white">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Estación · Bogotá</p>
                <p class="font-display text-base font-semibold">Cargando · 142 kW</p>
              </div>
              <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-500 text-white shadow-soft animate-pulse-soft">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden><path d="M14.69 2.66 9.5 12h4l-1.19 9.34L18 12h-4l1.19-9.34Z"/></svg>
              </div>
            </div>
          </div>

          <div class="absolute -left-10 top-10 hidden w-48 rounded-2xl border border-white/60 bg-white/80 p-4 shadow-soft backdrop-blur md:block">
            <div class="flex items-center gap-2">
              <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-100 text-brand-700">
                <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 13h2l3-9 4 18 3-9h6"/></svg>
              </span>
              <p class="text-xs font-semibold text-ink-900">Carga rápida DC</p>
            </div>
            <p class="mt-1 text-xs text-ink-700">120–360 kW · CCS2 + CHAdeMO</p>
          </div>

          <div class="absolute -right-6 bottom-16 hidden w-52 rounded-2xl border border-white/60 bg-white/80 p-4 shadow-soft backdrop-blur md:block">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">Hoy</p>
            <p class="font-display mt-0.5 text-2xl font-bold text-ink-950">$ 1’850.400 <span class="text-sm font-medium text-ink-500">COP</span></p>
            <div class="mt-2 flex h-1.5 overflow-hidden rounded-full bg-ink-100">
              <div class="h-full w-[72%] rounded-full bg-gradient-to-r from-brand-500 to-lime-glow"></div>
            </div>
            <p class="mt-1 text-xs text-ink-500">72% del objetivo diario</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
