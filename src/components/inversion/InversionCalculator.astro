---
const presets = [
  { hours: 3, label: "Bajo · 3 h/día" },
  { hours: 6, label: "Objetivo · 6 h/día" },
  { hours: 9, label: "Alto · 9 h/día" },
];
---
<section id="calculadora" class="relative overflow-hidden bg-linear-to-b from-white via-brand-50/30 to-white py-16 md:py-24">
  <div class="absolute inset-x-0 top-0 -z-10 h-72 bg-radial-fade opacity-60"></div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Calculadora de retorno</p>
      <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
        Simula tu inversión en tiempo real.
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Ajusta las horas de operación diarias y tu porcentaje de participación.
        Las cifras se actualizan al instante con la tasa de cambio en vivo.
      </p>
    </div>

    <div class="mt-10 md:mt-14 grid items-start gap-8 lg:grid-cols-12" data-calc-root>
      <!-- Controls panel -->
      <div class="lg:col-span-5">
        <div class="sticky top-24 rounded-4xl border border-ink-100 bg-white p-8 shadow-soft">
          <div class="flex items-center justify-between">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Tus supuestos</p>
            <div class="flex items-center gap-2 rounded-full border border-ink-100 bg-ink-50 px-3 py-1">
              <span class="h-2 w-2 rounded-full bg-brand-500 animate-pulse-soft"></span>
              <span class="text-[10px] font-semibold uppercase tracking-wider text-ink-700">
                FX <span data-fx-rate>—</span>
              </span>
            </div>
          </div>

          <div class="mt-8">
            <div class="flex items-baseline justify-between">
              <label for="calc-hours" class="text-sm font-semibold text-ink-950">Horas activas / día</label>
              <span class="font-display text-3xl font-bold text-brand-700">
                <span data-calc-hours-value>6</span><span class="text-base font-medium text-ink-500">h</span>
              </span>
            </div>
            <input
              id="calc-hours"
              type="range"
              min="1"
              max="12"
              step="1"
              value="6"
              class="calc-range mt-3 w-full"
              data-calc-hours
            />
            <div class="mt-2 flex justify-between text-[10px] font-medium text-ink-500">
              <span>1 h</span><span>6 h</span><span>12 h</span>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              {presets.map((p) => (
                <button
                  type="button"
                  data-calc-preset={p.hours}
                  class="rounded-full border border-ink-200 bg-white px-3 py-1.5 text-xs font-semibold text-ink-700 transition hover:border-brand-400 hover:text-brand-700"
                >
                  {p.label}
                </button>
              ))}
            </div>
          </div>

          <div class="mt-10">
            <div class="flex items-baseline justify-between">
              <label for="calc-pct" class="text-sm font-semibold text-ink-950">Tu participación</label>
              <span class="font-display text-3xl font-bold text-brand-700">
                <span data-calc-pct-value>20</span><span class="text-base font-medium text-ink-500">%</span>
              </span>
            </div>
            <input
              id="calc-pct"
              type="range"
              min="10"
              max="100"
              step="10"
              value="20"
              class="calc-range mt-3 w-full"
              data-calc-pct
            />
            <div class="mt-2 flex justify-between text-[10px] font-medium text-ink-500">
              <span>10%</span><span>50%</span><span>100%</span>
            </div>
          </div>

          <div class="mt-8 border-t border-ink-100 pt-6">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-ink-500">Constantes del modelo</p>
            <dl class="mt-3 grid grid-cols-2 gap-x-4 gap-y-2 text-xs">
              <dt class="text-ink-700">Capacidad / hora</dt><dd class="font-semibold text-ink-950 text-right">600 kWh</dd>
              <dt class="text-ink-700">Compra kWh</dt><dd class="font-semibold text-ink-950 text-right">$800 COP</dd>
              <dt class="text-ink-700">Venta kWh</dt><dd class="font-semibold text-ink-950 text-right">$1.600 COP</dd>
              <dt class="text-ink-700">Admin / mes</dt><dd class="font-semibold text-ink-950 text-right">$10M COP</dd>
              <dt class="text-ink-700">CAPEX total</dt><dd class="font-semibold text-ink-950 text-right">USD 190.000</dd>
            </dl>
          </div>
        </div>
      </div>

      <!-- Outputs panel -->
      <div class="lg:col-span-7 space-y-5">
        <!-- Investment summary -->
        <div class="rounded-4xl border border-brand-200 bg-linear-to-br from-ink-950 via-ink-900 to-brand-900 p-8 text-white shadow-glow">
          <div class="flex items-center justify-between gap-4">
            <p class="text-xs font-semibold uppercase tracking-widest text-brand-200">Tu inversión</p>
            <span class="rounded-full bg-white/10 px-3 py-1 text-[10px] font-semibold uppercase tracking-widest text-brand-100 backdrop-blur" data-calc-scenario>Escenario objetivo</span>
          </div>

          <div class="mt-4 grid items-baseline gap-2 sm:grid-cols-[auto_1fr] sm:gap-4">
            <p class="font-display text-5xl font-bold leading-none md:text-6xl" data-calc-investment-usd>USD 38.000</p>
            <p class="text-base text-ink-300"><span data-calc-investment-cop>$ 152.000.000 COP</span></p>
          </div>
          <p class="mt-3 text-sm text-ink-300">
            Equivale al <strong class="font-semibold text-lime-glow"><span data-calc-pct-display>20</span>%</strong>
            de una franquicia completa de USD 190.000.
          </p>
        </div>

        <!-- Monthly returns -->
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-ink-100 bg-white p-6 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Ingreso bruto / mes</p>
            <p class="font-display mt-3 text-3xl font-bold text-ink-950" data-calc-gross-usd>USD 3.600</p>
            <p class="mt-1 text-sm text-ink-500" data-calc-gross-cop>$ 14.400.000 COP</p>
            <p class="mt-3 text-xs text-ink-500">Tu participación sobre la facturación mensual proyectada.</p>
          </div>

          <div class="rounded-3xl border border-brand-200 bg-brand-50/60 p-6 shadow-soft ring-1 ring-inset ring-brand-200">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Utilidad / mes</p>
            <p class="font-display mt-3 text-3xl font-bold text-brand-800" data-calc-utility-usd>USD 4.366</p>
            <p class="mt-1 text-sm text-brand-700" data-calc-utility-cop>$ 15.280.000 COP</p>
            <p class="mt-3 text-xs text-ink-700">Margen energético menos costos administrativos prorrateados.</p>
          </div>
        </div>

        <!-- Annual + payback -->
        <div class="grid gap-5 sm:grid-cols-2">
          <div class="rounded-3xl border border-ink-100 bg-white p-6 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Utilidad anual</p>
            <p class="font-display mt-3 text-3xl font-bold text-ink-950" data-calc-annual-usd>USD 52.392</p>
            <p class="mt-1 text-sm text-ink-500" data-calc-annual-cop>$ 183.360.000 COP</p>
            <p class="mt-3 text-xs text-ink-500">Tu participación sobre la utilidad operativa de los 12 meses.</p>
          </div>

          <div class="rounded-3xl border border-lime-glow/40 bg-linear-to-br from-lime-glow/20 to-brand-50 p-6 shadow-soft">
            <p class="text-[10px] font-bold uppercase tracking-widest text-brand-700">Payback proyectado</p>
            <p class="font-display mt-3 text-3xl font-bold text-brand-900">
              <span data-calc-payback>8.6</span><span class="ml-1 text-base font-semibold text-ink-700">meses</span>
            </p>
            <p class="mt-3 text-xs text-ink-700">Tiempo para recuperar la inversión a las horas y participación seleccionadas.</p>
          </div>
        </div>

        <p class="text-center text-xs text-ink-500">
          Cifras estimadas con la tasa de cambio en vivo USD → COP.
          No constituyen oferta vinculante; proyección sujeta a tráfico, tarifa eléctrica y operación.
        </p>

        <div class="text-center">
          <a href="#contacto" class="inline-flex items-center gap-1.5 rounded-full bg-ink-950 px-6 py-3.5 text-sm font-semibold text-white transition hover:bg-brand-700">
            Hablar con un asesor
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .calc-range {
    appearance: none;
    -webkit-appearance: none;
    background: transparent;
    height: 28px;
    width: 100%;
  }
  .calc-range::-webkit-slider-runnable-track {
    height: 6px;
    border-radius: 9999px;
    background: linear-gradient(
      to right,
      oklch(0.55 0.17 152) 0%,
      oklch(0.55 0.17 152) var(--calc-fill, 50%),
      oklch(0.94 0.01 160) var(--calc-fill, 50%),
      oklch(0.94 0.01 160) 100%
    );
  }
  .calc-range::-moz-range-track {
    height: 6px;
    border-radius: 9999px;
    background: oklch(0.94 0.01 160);
  }
  .calc-range::-moz-range-progress {
    height: 6px;
    border-radius: 9999px;
    background: oklch(0.55 0.17 152);
  }
  .calc-range::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 9999px;
    background: white;
    border: 4px solid oklch(0.46 0.14 152);
    box-shadow: 0 4px 12px oklch(0.55 0.17 152 / 0.4);
    margin-top: -9px;
    cursor: grab;
    transition: transform 0.15s ease;
  }
  .calc-range::-webkit-slider-thumb:active { cursor: grabbing; transform: scale(1.1); }
  .calc-range::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 9999px;
    background: white;
    border: 4px solid oklch(0.46 0.14 152);
    box-shadow: 0 4px 12px oklch(0.55 0.17 152 / 0.4);
    cursor: grab;
  }
  .calc-range:focus {
    outline: none;
  }
  .calc-range:focus::-webkit-slider-thumb {
    box-shadow: 0 0 0 4px oklch(0.88 0.10 152 / 0.5);
  }
</style>

<script>
  const FALLBACK_FX = 4100;
  const CAPEX_USD = 190_000;
  const CAPACITY_KWH_PER_HOUR = 600;
  const PRICE_KWH_COP = 1600;
  const COST_KWH_COP = 800;
  const ADMIN_MONTHLY_COP = 10_000_000;
  const DAYS_PER_MONTH = 30;

  type CalcState = { hours: number; pct: number; fxCop: number };

  const root = document.querySelector<HTMLElement>('[data-calc-root]');
  if (root) {
    const hoursInput = root.querySelector<HTMLInputElement>('[data-calc-hours]')!;
    const pctInput   = root.querySelector<HTMLInputElement>('[data-calc-pct]')!;
    const hoursVal   = root.querySelector<HTMLElement>('[data-calc-hours-value]')!;
    const pctVal     = root.querySelector<HTMLElement>('[data-calc-pct-value]')!;
    const pctDisplay = root.querySelector<HTMLElement>('[data-calc-pct-display]')!;
    const fxBadge    = root.querySelector<HTMLElement>('[data-fx-rate]')!;
    const scenarioBadge = root.querySelector<HTMLElement>('[data-calc-scenario]')!;
    const investUsdEl = root.querySelector<HTMLElement>('[data-calc-investment-usd]')!;
    const investCopEl = root.querySelector<HTMLElement>('[data-calc-investment-cop]')!;
    const grossUsdEl  = root.querySelector<HTMLElement>('[data-calc-gross-usd]')!;
    const grossCopEl  = root.querySelector<HTMLElement>('[data-calc-gross-cop]')!;
    const utilUsdEl   = root.querySelector<HTMLElement>('[data-calc-utility-usd]')!;
    const utilCopEl   = root.querySelector<HTMLElement>('[data-calc-utility-cop]')!;
    const annUsdEl    = root.querySelector<HTMLElement>('[data-calc-annual-usd]')!;
    const annCopEl    = root.querySelector<HTMLElement>('[data-calc-annual-cop]')!;
    const paybackEl   = root.querySelector<HTMLElement>('[data-calc-payback]')!;
    const presetBtns  = root.querySelectorAll<HTMLButtonElement>('[data-calc-preset]');

    const fmtCop = (n: number) =>
      '$ ' + Math.round(n).toLocaleString('es-CO').replace(/,/g, '.') + ' COP';
    const fmtUsd = (n: number) =>
      'USD ' + Math.round(n).toLocaleString('en-US');
    const fmtFx = (n: number) =>
      'USD = $' + Math.round(n).toLocaleString('es-CO').replace(/,/g, '.');

    const setFill = (el: HTMLInputElement) => {
      const min = Number(el.min);
      const max = Number(el.max);
      const val = Number(el.value);
      const pct = ((val - min) / (max - min)) * 100;
      el.style.setProperty('--calc-fill', pct + '%');
    };

    const state: CalcState = {
      hours: Number(hoursInput.value) || 6,
      pct:   Number(pctInput.value) || 20,
      fxCop: FALLBACK_FX,
    };

    function compute(s: CalcState) {
      const kwhPerDay   = s.hours * CAPACITY_KWH_PER_HOUR;
      const grossDayCop = kwhPerDay * PRICE_KWH_COP;
      const costDayCop  = kwhPerDay * COST_KWH_COP;
      const grossMonthCop = grossDayCop * DAYS_PER_MONTH;
      const costMonthCop  = costDayCop * DAYS_PER_MONTH;
      const energyMarginMonthCop = grossMonthCop - costMonthCop;
      const utilityMonthCop = energyMarginMonthCop - ADMIN_MONTHLY_COP;

      const share = s.pct / 100;
      const investorInvUsd = CAPEX_USD * share;
      const investorGrossMonthCop = grossMonthCop * share;
      const investorUtilityMonthCop = utilityMonthCop * share;
      const investorAnnualUtilityCop = investorUtilityMonthCop * 12;

      const capexCop = CAPEX_USD * s.fxCop;
      const paybackMonths = utilityMonthCop > 0
        ? capexCop / utilityMonthCop
        : Infinity;

      return {
        investorInvUsd,
        investorInvCop: investorInvUsd * s.fxCop,
        investorGrossMonthCop,
        investorGrossMonthUsd: investorGrossMonthCop / s.fxCop,
        investorUtilityMonthCop,
        investorUtilityMonthUsd: investorUtilityMonthCop / s.fxCop,
        investorAnnualUtilityCop,
        investorAnnualUtilityUsd: investorAnnualUtilityCop / s.fxCop,
        paybackMonths,
      };
    }

    function scenarioLabel(hours: number) {
      if (hours <= 3) return 'Escenario bajo · ' + hours + ' h/día';
      if (hours <= 6) return 'Escenario objetivo · ' + hours + ' h/día';
      return 'Escenario alto · ' + hours + ' h/día';
    }

    function render() {
      const r = compute(state);
      hoursVal.textContent = String(state.hours);
      pctVal.textContent   = String(state.pct);
      pctDisplay.textContent = String(state.pct);
      scenarioBadge.textContent = scenarioLabel(state.hours);
      fxBadge.textContent = fmtFx(state.fxCop);

      investUsdEl.textContent = fmtUsd(r.investorInvUsd);
      investCopEl.textContent = fmtCop(r.investorInvCop);

      const gross = r.investorGrossMonthCop > 0 ? r.investorGrossMonthCop : 0;
      grossUsdEl.textContent = fmtUsd(gross / state.fxCop);
      grossCopEl.textContent = fmtCop(gross);

      const utility = r.investorUtilityMonthCop;
      utilUsdEl.textContent = fmtUsd(utility / state.fxCop);
      utilCopEl.textContent = fmtCop(utility);

      annUsdEl.textContent = fmtUsd(r.investorAnnualUtilityUsd);
      annCopEl.textContent = fmtCop(r.investorAnnualUtilityCop);

      if (!isFinite(r.paybackMonths) || r.paybackMonths < 0) {
        paybackEl.textContent = '—';
      } else if (r.paybackMonths > 99) {
        paybackEl.textContent = '99+';
      } else {
        paybackEl.textContent = r.paybackMonths.toFixed(1);
      }

      setFill(hoursInput);
      setFill(pctInput);
    }

    hoursInput.addEventListener('input', () => {
      state.hours = Number(hoursInput.value);
      render();
    });
    pctInput.addEventListener('input', () => {
      state.pct = Number(pctInput.value);
      render();
    });
    presetBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const h = Number(btn.dataset.calcPreset);
        if (Number.isFinite(h)) {
          state.hours = h;
          hoursInput.value = String(h);
          render();
        }
      });
    });

    render();

    fetch('/api/fx')
      .then((r) => r.ok ? r.json() : Promise.reject(r.status))
      .then((data) => {
        const cop = Number(data?.cop);
        if (Number.isFinite(cop) && cop > 0) {
          state.fxCop = cop;
          render();
        }
      })
      .catch(() => { /* keep fallback */ });
  }
</script>
