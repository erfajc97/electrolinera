---
const shares = [
  { usd: 19000,  pct: 10,  ret: 1800,  tag: "Entrada" },
  { usd: 38000,  pct: 20,  ret: 3600,  tag: "Diversificación" },
  { usd: 57000,  pct: 30,  ret: 5400,  tag: "Crecimiento" },
  { usd: 95000,  pct: 50,  ret: 9000,  tag: "Control compartido", featured: true },
  { usd: 190000, pct: 100, ret: 18000, tag: "Propiedad total" },
];

const benefits = [
  "Participación accionaria proporcional",
  "Contrato de inversión privada",
  "Distribución periódica de utilidades",
  "Derecho proporcional sobre valorización del activo",
];
---
<section id="participacion" class="relative bg-ink-50 py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Tabla de participación</p>
      <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
        Elige cuánto quieres ser dueño.
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Cada inversionista adquiere un porcentaje real de la electrolinera —
        utilidades, valorización y propiedad del activo proporcional al aporte.
      </p>
    </div>

    <div class="mt-10 md:mt-14 grid gap-4 md:grid-cols-5">
      {shares.map((s) => (
        <article class={`relative flex flex-col rounded-3xl border p-6 transition hover:-translate-y-1 ${s.featured ? "border-brand-500 bg-ink-950 text-white shadow-glow" : "border-ink-100 bg-white text-ink-950 shadow-soft hover:border-brand-200"}`}>
          {s.featured && <span class="absolute -top-3 left-1/2 -translate-x-1/2 rounded-full bg-lime-glow px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-ink-950 shadow-soft whitespace-nowrap">recomendado</span>}
          <p class={`text-[10px] font-bold uppercase tracking-widest ${s.featured ? "text-brand-200" : "text-brand-700"}`}>{s.tag}</p>
          <p class={`font-display mt-3 text-4xl font-bold ${s.featured ? "text-lime-glow" : "text-ink-950"}`}>{s.pct}%</p>
          <p class={`mt-1 text-xs ${s.featured ? "text-ink-300" : "text-ink-500"}`}>de la electrolinera</p>

          <div class={`mt-5 border-t pt-4 ${s.featured ? "border-white/15" : "border-ink-100"}`}>
            <p class={`text-[10px] font-semibold uppercase tracking-widest ${s.featured ? "text-brand-200" : "text-ink-500"}`}>Inversión</p>
            <p class="font-display mt-1 text-lg font-bold">USD {s.usd.toLocaleString("en-US")}</p>
          </div>

          <div class={`mt-3 border-t pt-4 ${s.featured ? "border-white/15" : "border-ink-100"}`}>
            <p class={`text-[10px] font-semibold uppercase tracking-widest ${s.featured ? "text-brand-200" : "text-ink-500"}`}>Retorno bruto / mes</p>
            <p class={`font-display mt-1 text-lg font-bold ${s.featured ? "text-lime-glow" : "text-brand-700"}`}>≈ USD {s.ret.toLocaleString("en-US")}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-10 grid gap-6 lg:grid-cols-12">
      <div class="lg:col-span-7 rounded-3xl border border-ink-100 bg-white p-6 shadow-soft">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Estructura del negocio</p>
        <h3 class="font-display mt-2 text-xl font-bold text-ink-950">Qué recibes como inversionista</h3>
        <ul class="mt-4 grid gap-2 sm:grid-cols-2">
          {benefits.map((b) => (
            <li class="flex items-start gap-2 text-sm text-ink-800">
              <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
              {b}
            </li>
          ))}
        </ul>
      </div>
      <div class="lg:col-span-5 rounded-3xl border border-brand-200 bg-brand-50/60 p-6 shadow-soft">
        <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Retornos proyectados</p>
        <h3 class="font-display mt-2 text-xl font-bold text-ink-950">Sobre facturación mínima</h3>
        <p class="mt-2 text-sm text-ink-700">
          Los retornos por participación de la tabla asumen el escenario
          objetivo de 6 h/día (USD 18.000 facturados al mes).
          En la calculadora puedes simular con tus propios supuestos.
        </p>
        <a href="#calculadora" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-brand-700 hover:text-brand-800">
          Ir a la calculadora
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>
      </div>
    </div>
  </div>
</section>
