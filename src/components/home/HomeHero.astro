---
---
<section id="top" class="relative isolate overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="absolute inset-0 -z-10 bg-radial-fade"></div>
  <div class="absolute inset-0 -z-10 bg-grid"></div>
  <div class="absolute inset-0 -z-10 bg-grid-beam"></div>

  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <span class="hero-spark" style="--x:8%;  --d:0s;   --dur:9s;"></span>
    <span class="hero-spark" style="--x:22%; --d:1.4s; --dur:11s;"></span>
    <span class="hero-spark" style="--x:35%; --d:3.2s; --dur:8s;"></span>
    <span class="hero-spark" style="--x:48%; --d:0.6s; --dur:13s;"></span>
    <span class="hero-spark" style="--x:62%; --d:2.1s; --dur:10s;"></span>
    <span class="hero-spark" style="--x:75%; --d:4s;   --dur:12s;"></span>
    <span class="hero-spark" style="--x:88%; --d:1.8s; --dur:9.5s;"></span>
  </div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <a href="#soluciones" class="group inline-flex items-center gap-2 rounded-full border border-brand-200 bg-white/70 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 backdrop-blur">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-brand-500 text-[10px] text-white">★</span>
          Solar · Movilidad · Electrolineras
          <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <h1 class="font-display mt-6 text-balance text-5xl font-bold leading-[1.02] tracking-tight text-ink-950 md:text-6xl lg:text-7xl">
          Energía
          <span class="relative whitespace-nowrap">
            <span class="bg-linear-to-r from-brand-600 via-brand-500 to-brand-700 bg-clip-text text-transparent">inteligente</span>
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12" fill="none" aria-hidden>
              <path d="M2 9 C 80 2, 160 2, 298 9" stroke="oklch(0.64 0.18 152)" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
          para un futuro sostenible.
        </h1>

        <p class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-ink-700">
          Disart Energy diseña, importa, instala y opera infraestructura energética
          de alto impacto. Solar, movilidad eléctrica y electrolineras — todo bajo
          un solo aliado de ingeniería en Colombia y Latinoamérica.
        </p>

        <div class="mt-8 flex flex-wrap items-center gap-3">
          <a href="#contacto" class="group inline-flex items-center gap-2 rounded-full bg-brand-600 px-6 py-3.5 text-sm font-semibold text-white shadow-glow transition hover:bg-brand-700">
            Cotizar mi proyecto
            <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="#soluciones" class="inline-flex items-center gap-2 rounded-full border border-ink-300 bg-white/60 px-6 py-3.5 text-sm font-semibold text-ink-900 backdrop-blur transition hover:border-brand-400 hover:text-brand-700">
            Ver soluciones
          </a>
        </div>

        <dl class="mt-12 grid max-w-md grid-cols-3 gap-6">
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Proyectos</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">+120</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">MWp instalados</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">8.4</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">CO₂ evitado</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-brand-600">↓ 6.2 kt</dd>
          </div>
        </dl>
      </div>

      <div class="relative lg:col-span-5">
        <!-- Stacked image collage of the 3 service lines -->
        <div class="relative mx-auto aspect-4/5 max-w-md">
          <div class="absolute -inset-6 rounded-4xl bg-linear-to-br from-brand-200/60 to-lime-glow/40 blur-2xl"></div>

          <!-- Solar farm hero -->
          <div class="absolute inset-0 overflow-hidden rounded-4xl border border-white/60 shadow-glow">
            <img src="/img/solar/utility-farm.jpg" alt="Planta solar utility-scale" class="h-full w-full object-cover" loading="eager" fetchpriority="high"/>
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-linear-to-t from-ink-950/85 to-transparent"></div>
            <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between gap-3">
              <div class="text-white">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Utility scale · Colombia</p>
                <p class="font-display text-base font-semibold">390 MW identificados</p>
              </div>
              <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-500 text-white shadow-soft animate-pulse-soft">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden><path d="M14.69 2.66 9.5 12h4l-1.19 9.34L18 12h-4l1.19-9.34Z"/></svg>
              </div>
            </div>
          </div>

          <!-- EV floating card (video showroom) -->
          <div class="absolute -left-8 top-8 hidden w-44 overflow-hidden rounded-2xl border border-white/60 bg-white shadow-soft md:block">
            <video src="/video/vehiculos/showroom-loop.mp4" autoplay loop muted playsinline preload="metadata" class="h-24 w-full object-cover"></video>
            <div class="p-3">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">Movilidad eléctrica</p>
              <p class="font-display text-xs font-bold text-ink-950">Importación directa</p>
            </div>
          </div>

          <!-- Charger floating card -->
          <div class="absolute -right-6 bottom-12 hidden w-48 overflow-hidden rounded-2xl border border-white/60 bg-white shadow-soft md:block">
            <img src="/img/electrolinera/station-ev-fast.png" alt="Cargador DC en operación" class="h-24 w-full object-cover" loading="lazy" />
            <div class="p-3">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">Electrolineras</p>
              <p class="font-display text-xs font-bold text-ink-950">DC Fast Charging</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
