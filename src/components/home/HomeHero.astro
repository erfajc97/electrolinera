---
---
<section id="top" class="relative isolate overflow-hidden pt-28 pb-20 md:pt-36 md:pb-28">
  <div class="absolute inset-0 -z-10 bg-radial-fade"></div>
  <div class="absolute inset-0 -z-10 bg-grid"></div>
  <div class="absolute inset-0 -z-10 bg-grid-beam"></div>

  <div class="pointer-events-none absolute inset-0 -z-10 overflow-hidden">
    <span class="hero-spark" style="--x:8%;  --d:0s;   --dur:9s;"></span>
    <span class="hero-spark" style="--x:22%; --d:1.4s; --dur:11s;"></span>
    <span class="hero-spark" style="--x:35%; --d:3.2s; --dur:8s;"></span>
    <span class="hero-spark" style="--x:48%; --d:0.6s; --dur:13s;"></span>
    <span class="hero-spark" style="--x:62%; --d:2.1s; --dur:10s;"></span>
    <span class="hero-spark" style="--x:75%; --d:4s;   --dur:12s;"></span>
    <span class="hero-spark" style="--x:88%; --d:1.8s; --dur:9.5s;"></span>
  </div>

  <div class="mx-auto max-w-6xl px-4">
    <div class="grid items-center gap-12 lg:grid-cols-12">
      <div class="lg:col-span-7">
        <a href="/inversion" class="group inline-flex items-center gap-2 rounded-full border border-brand-300 bg-white/80 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-brand-700 shadow-soft backdrop-blur transition hover:border-brand-500">
          <span class="grid h-4 w-4 place-items-center rounded-full bg-brand-600 text-[10px] text-white">★</span>
          Ronda de inversión 2026 abierta · cupos limitados
          <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <h1 class="font-display mt-6 text-balance text-5xl font-bold leading-[1.02] tracking-tight text-ink-950 md:text-6xl lg:text-7xl">
          Invierte en la red de
          <span class="relative whitespace-nowrap">
            <span class="bg-linear-to-r from-brand-600 via-brand-500 to-brand-700 bg-clip-text text-transparent">electrolineras</span>
            <svg class="absolute -bottom-2 left-0 w-full" viewBox="0 0 300 12" fill="none" aria-hidden>
              <path d="M2 9 C 80 2, 160 2, 298 9" stroke="oklch(0.64 0.18 152)" stroke-width="3" stroke-linecap="round"/>
            </svg>
          </span>
          que mueve a Colombia.
        </h1>

        <p class="mt-6 max-w-xl text-pretty text-lg leading-relaxed text-ink-700">
          Disart Energy diseña, importa, instala y opera electrolineras de carga
          ultra rápida — <strong class="font-semibold text-ink-900">720&nbsp;kW por estación</strong>.
          Con permisos, certificaciones y la infraestructura ya lista, conviertes
          tu capital en flujo recurrente y un activo de largo plazo.
        </p>

        <div class="mt-8 flex flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
          <a href="/inversion" class="group inline-flex items-center justify-center gap-2 rounded-full bg-linear-to-r from-brand-600 to-brand-700 px-6 py-4 text-base font-bold text-white shadow-glow ring-1 ring-inset ring-white/15 transition hover:from-brand-700 hover:to-brand-800 sm:text-sm">
            <span class="h-1.5 w-1.5 rounded-full bg-lime-glow animate-pulse-soft"></span>
            Calcular mi retorno
            <svg class="h-4 w-4 transition group-hover:translate-x-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
          </a>
          <a href="/electrolineras" class="inline-flex items-center justify-center gap-2 rounded-full border border-ink-300 bg-white/60 px-6 py-3.5 text-sm font-semibold text-ink-900 backdrop-blur transition hover:border-brand-400 hover:text-brand-700">
            Ver electrolineras
          </a>
        </div>

        <dl class="mt-12 grid max-w-md grid-cols-3 gap-6">
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Por estación</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">720 kW</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Payback objetivo</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-ink-950">8.6 mo</dd>
          </div>
          <div>
            <dt class="text-xs font-medium uppercase tracking-wider text-ink-500">Margen kWh</dt>
            <dd class="font-display mt-1 text-2xl font-bold text-brand-600">2×</dd>
          </div>
        </dl>

        <p class="mt-6 text-xs text-ink-500">
          También operamos <a href="/solar" class="font-semibold text-ink-700 underline-offset-2 hover:underline">energía solar</a>
          e <a href="/movilidad" class="font-semibold text-ink-700 underline-offset-2 hover:underline">importación de vehículos eléctricos</a>.
        </p>
      </div>

      <div class="relative lg:col-span-5">
        <div class="relative mx-auto aspect-3/4 max-w-md">
          <div class="absolute -inset-6 rounded-4xl bg-linear-to-br from-brand-200/60 to-lime-glow/40 blur-2xl"></div>

          <div class="relative h-full overflow-hidden rounded-4xl border border-white/60 shadow-glow">
            <img src="/img/electrolinera/charger-rain-suv.jpg" alt="Electrolinera Disart Energy en operación" class="h-full w-full object-cover" loading="eager" decoding="sync" fetchpriority="high"/>
            <div class="absolute inset-x-0 bottom-0 h-1/2 bg-linear-to-t from-ink-950/85 to-transparent"></div>
            <div class="absolute bottom-5 left-5 right-5 flex items-end justify-between gap-3">
              <div class="text-white">
                <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Estación · DC Fast</p>
                <p class="font-display text-base font-semibold">3 × 240 kW · 6 mangueras</p>
              </div>
              <div class="grid h-12 w-12 place-items-center rounded-2xl bg-brand-500 text-white shadow-soft animate-pulse-soft">
                <svg viewBox="0 0 24 24" class="h-6 w-6" fill="currentColor" aria-hidden><path d="M14.69 2.66 9.5 12h4l-1.19 9.34L18 12h-4l1.19-9.34Z"/></svg>
              </div>
            </div>
          </div>

          <div class="absolute -left-8 top-8 hidden w-48 overflow-hidden rounded-2xl border border-white/60 bg-white/90 shadow-soft backdrop-blur md:block">
            <div class="p-3">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">Compra kWh</p>
              <p class="font-display text-lg font-bold text-ink-950">$800 <span class="text-xs font-medium text-ink-500">COP</span></p>
              <p class="text-[10px] text-ink-500">a empresa eléctrica</p>
            </div>
          </div>

          <div class="absolute -right-6 bottom-12 hidden w-48 overflow-hidden rounded-2xl border border-white/60 bg-white/90 shadow-soft backdrop-blur md:block">
            <div class="p-3">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-700">Venta kWh</p>
              <p class="font-display text-lg font-bold text-brand-700">$1.600 <span class="text-xs font-medium text-ink-500">COP</span></p>
              <p class="text-[10px] text-ink-500">público · margen $800</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
