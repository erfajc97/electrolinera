---
const featured = {
  href: "/electrolineras",
  invest: "/inversion",
  tag: "Electrolineras · Foco 2026",
  icon: '<path d="M14 2 5 14h7l-2 8 9-12h-7l2-8Z"/>',
  image: "/img/electrolinera/charger-rain-suv.jpg",
  title: "Electrolineras de carga ultra rápida",
  pitch: "La oportunidad de inversión que mueve a Colombia.",
  bullets: [
    "3 cargadores DC × 240 kW · 720 kW por estación · 6 mangueras",
    "Margen 2× sobre el kWh — compra $800, vende $1.600 COP",
    "Llave en mano: permisos, certificaciones e importación incluidas",
    "App + dashboard SaaS con opción de marca blanca personalizada",
    "Payback objetivo desde 8.6 meses (6 h/día de uso)",
  ],
  ctaPrimary: "Calcular mi retorno",
  ctaSecondary: "Ver la franquicia",
};

const secondary = [
  {
    href: "/movilidad",
    tag: "Movilidad",
    icon: '<path d="M5 17h14"/><path d="M5 17a2 2 0 1 0 4 0M15 17a2 2 0 1 0 4 0"/><path d="M3 13l2-5h14l2 5v4H3v-4Z"/>',
    video: "/video/vehiculos/showroom-loop.mp4",
    image: null,
    title: "Movilidad eléctrica",
    pitch: "Importamos vehículos e infraestructura corporativa.",
    bullets: [
      "Importación directa de vehículos eléctricos",
      "Flotas corporativas y last-mile",
      "Carga in-house + integración solar",
    ],
    cta: "Importar mi vehículo",
  },
  {
    href: "/solar",
    tag: "Solar",
    icon: '<circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M5 19l2-2M17 7l2-2"/>',
    video: null,
    image: "/img/solar/rooftop-village.jpg",
    title: "Energía solar",
    pitch: "Transformamos la luz del sol en ahorro real.",
    bullets: [
      "Ingeniería fotovoltaica On-Grid / Off-Grid / híbrido",
      "Residencial, comercial e industrial",
      "Mantenimiento + monitoreo inteligente",
    ],
    cta: "Ver soluciones solares",
  },
];
---
<section id="soluciones" class="relative py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Nuestras soluciones</p>
      <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
        Una sola compañía. Tres frentes de la transición energética.
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Nuestro foco prioritario son las electrolineras — el activo energético
        con mayor crecimiento en Colombia. Complementamos con energía solar
        e importación de vehículos eléctricos.
      </p>
    </div>

    <article class="group relative mt-10 md:mt-14 overflow-hidden rounded-4xl border border-brand-200 bg-ink-950 shadow-glow">
      <div class="grid gap-0 lg:grid-cols-12">
        <div class="relative aspect-16/10 overflow-hidden lg:col-span-7 lg:aspect-auto">
          <img src={featured.image} alt={featured.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.03]" loading="eager" />
          <div class="absolute inset-0 bg-linear-to-r from-ink-950/40 via-ink-950/15 to-transparent lg:bg-linear-to-r"></div>
          <div class="absolute inset-0 bg-linear-to-t from-ink-950/80 via-transparent to-transparent"></div>
          <span class="absolute left-5 top-5 inline-flex items-center gap-1.5 rounded-full bg-brand-600 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white shadow-soft">
            <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={featured.icon} />
            {featured.tag}
          </span>
          <div class="absolute inset-x-5 bottom-5 hidden gap-3 lg:flex">
            <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white backdrop-blur">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Inversión</p>
              <p class="font-display text-base font-bold">desde USD 19k</p>
            </div>
            <div class="rounded-2xl border border-white/15 bg-white/10 px-4 py-3 text-white backdrop-blur">
              <p class="text-[10px] font-semibold uppercase tracking-widest text-brand-200">Participación</p>
              <p class="font-display text-base font-bold">10% — 100%</p>
            </div>
          </div>
        </div>

        <div class="flex flex-col p-8 text-white lg:col-span-5 lg:p-10">
          <h3 class="font-display text-3xl font-bold leading-tight md:text-4xl">{featured.title}</h3>
          <p class="mt-3 text-base italic text-brand-200">{featured.pitch}</p>
          <ul class="mt-6 space-y-2.5 text-sm text-ink-100">
            {featured.bullets.map((b) => (
              <li class="flex items-start gap-2.5">
                <svg class="mt-0.5 h-4 w-4 shrink-0 text-lime-glow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                {b}
              </li>
            ))}
          </ul>
          <div class="mt-8 flex flex-wrap gap-2.5">
            <a href={featured.invest} class="inline-flex items-center gap-1.5 rounded-full bg-lime-glow px-5 py-3 text-sm font-bold text-ink-950 transition hover:bg-white">
              {featured.ctaPrimary}
              <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
            <a href={featured.href} class="inline-flex items-center gap-1.5 rounded-full border border-white/30 px-5 py-3 text-sm font-semibold text-white transition hover:bg-white/10">
              {featured.ctaSecondary}
            </a>
          </div>
        </div>
      </div>
    </article>

    <div class="mt-6 grid gap-6 lg:grid-cols-2">
      {secondary.map((s) => (
        <article class="group relative flex flex-col overflow-hidden rounded-3xl border border-ink-100 bg-white shadow-soft transition hover:-translate-y-1 hover:border-brand-200">
          <div class="relative aspect-16/9 overflow-hidden">
            {s.video ? (
              <video src={s.video} autoplay loop muted playsinline preload="metadata" class="h-full w-full object-cover transition duration-700 group-hover:scale-105"></video>
            ) : (
              <img src={s.image!} alt={s.title} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" decoding="async" />
            )}
            <div class="absolute inset-0 bg-linear-to-t from-ink-950/55 via-transparent"></div>
            <span class="absolute left-4 top-4 inline-flex items-center gap-1.5 rounded-full bg-white/90 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-brand-700 backdrop-blur">
              <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" set:html={s.icon} />
              {s.tag}
            </span>
          </div>

          <div class="flex flex-1 flex-col p-6">
            <h3 class="font-display text-xl font-bold text-ink-950">{s.title}</h3>
            <p class="mt-2 text-sm italic text-brand-700">{s.pitch}</p>
            <ul class="mt-4 space-y-2 text-sm text-ink-700">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2">
                  <svg class="mt-0.5 h-4 w-4 shrink-0 text-brand-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  {b}
                </li>
              ))}
            </ul>
            <a href={s.href} class="mt-5 inline-flex items-center justify-center gap-1.5 rounded-full bg-ink-950 px-4 py-2.5 text-sm font-semibold text-white transition group-hover:bg-brand-700">
              {s.cta}
              <svg class="h-3.5 w-3.5 transition group-hover:translate-x-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
