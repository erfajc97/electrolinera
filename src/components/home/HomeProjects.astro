---
const items = [
  { v: "390", u: "MW",  t: "Utility scale en zonas de alta radiación", img: "/img/solar/utility-farm.jpg" },
  { v: "17",  u: "GD",  t: "Proyectos de generación distribuida (1 MW c/u)", img: "/img/solar/installer-pole.jpg" },
  { v: "5",   u: "ZE",  t: "Comunidades energéticas en zonas PDET y ZOMAC", img: "/img/solar/kids-rural-panel.jpg" },
  { v: "22",  u: "AGPE",t: "Autogeneradores comerciales a pequeña escala", img: "/img/solar/rooftop-village.jpg" },
  { v: "10",  u: "PIL.",t: "Pilotos solares en colegios", img: "/img/solar/installer-hilltop.jpg" },
  { v: "∞",   u: "luz", t: "Alumbrado solar público y rural", img: "/img/solar/mountain-house.jpg" },
];
---
<section class="relative py-16 md:py-24">
  <div class="mx-auto max-w-6xl px-4">
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-brand-700">Lo que hemos construido</p>
      <h2 class="font-display mt-3 text-balance text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
        Energía en cada rincón para un futuro más sostenible.
      </h2>
      <p class="mt-4 text-lg text-ink-700">
        Más de una década entregando proyectos de energía limpia en Colombia,
        desde grandes plantas utility-scale hasta comunidades rurales.
      </p>
    </div>

    <div class="mt-10 md:mt-14 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {items.map((i) => (
        <article class="group relative overflow-hidden rounded-3xl border border-ink-100 bg-ink-950 shadow-soft transition hover:-translate-y-1">
          <img src={i.img} alt={i.t} class="absolute inset-0 h-full w-full object-cover opacity-50 transition duration-700 group-hover:scale-105 group-hover:opacity-65" loading="lazy" decoding="async" />
          <div class="absolute inset-0 bg-gradient-to-t from-ink-950 via-ink-950/70"></div>
          <div class="relative p-6 text-white min-h-[180px] flex flex-col justify-end">
            <p class="font-display text-5xl font-bold leading-none tracking-tight">{i.v}<span class="ml-1 text-sm font-semibold text-lime-glow">{i.u}</span></p>
            <p class="mt-2 text-sm text-ink-200">{i.t}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
