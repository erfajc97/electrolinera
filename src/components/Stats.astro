---
const stats = [
  { v: "720", u: "kW",   t: "por estación: 3 cargadores × 240 kW · 6 mangueras" },
  { v: "2×",  u: "",     t: "margen sobre kWh — compra $800, vende $1.600 COP" },
  { v: "8.6", u: "meses",t: "payback proyectado (escenario objetivo 6 h/día)" },
  { v: "24×7",u: "",     t: "monitoreo, mantenimiento y soporte incluidos" },
];
---
<section class="relative -mt-12 px-4">
  <div class="mx-auto max-w-6xl">
    <div class="grid gap-px overflow-hidden rounded-3xl border border-ink-100 bg-ink-100 shadow-soft sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((s) => (
        <div class="bg-white p-8">
          <p class="font-display text-4xl font-bold tracking-tight text-ink-950 md:text-5xl">
            {s.v}
            {s.u && <span class="ml-1 text-base font-semibold text-brand-700">{s.u}</span>}
          </p>
          <p class="mt-2 text-sm text-ink-700">{s.t}</p>
        </div>
      ))}
    </div>
  </div>
</section>
