---
import Logo from "./Logo.astro";
import { CONTACT, CONTACT_MAILTO } from "../config/contact";

const year = new Date().getFullYear();
const cols = [
  { t: "Soluciones", links: [
    { label: "Energía solar", href: "/solar" },
    { label: "Movilidad eléctrica", href: "/movilidad" },
    { label: "Electrolineras", href: "/electrolineras" },
    { label: "Almacenamiento", href: "/#contacto" },
  ]},
  { t: "Empresa", links: [
    { label: "Nosotros", href: "/#nosotros" },
    { label: "Proceso", href: "/#proceso" },
    { label: "Casos", href: "/#contacto" },
    { label: "Carreras", href: "/#contacto" },
  ]},
  { t: "Recursos", links: [
    { label: "Centro de ayuda", href: "/#contacto" },
    { label: "Blog", href: "/#contacto" },
    { label: "Sostenibilidad", href: "/#nosotros" },
    { label: "Privacidad", href: "/privacidad" },
    { label: "Términos y condiciones", href: "/terminos" },
  ]},
  { t: "Contacto", links: [
    { label: "WhatsApp", href: "/#contacto" },
    { label: CONTACT.email, href: CONTACT_MAILTO },
    { label: `${CONTACT.city} · ${CONTACT.country}`, href: "/#contacto" },
    { label: "Estado del servicio", href: "/#contacto" },
  ]},
];
---
<footer class="border-t border-ink-100 bg-white">
  <div class="mx-auto max-w-6xl px-4 py-16">
    <div class="grid gap-10 lg:grid-cols-12">
      <div class="lg:col-span-4">
        <Logo />
        <p class="mt-4 max-w-xs text-sm text-ink-700">
          Energía limpia que también es buen negocio.
          Electrolineras llave en mano y soluciones solares en toda Colombia.
        </p>
        <div class="mt-6 flex items-center gap-2">
          {[
            "M22 5.8v12.4c0 1.5-1.3 2.8-2.8 2.8H4.8C3.3 21 2 19.7 2 18.2V5.8C2 4.3 3.3 3 4.8 3h14.4C20.7 3 22 4.3 22 5.8ZM7.5 17.5v-7H4.7v7h2.8Zm-1.4-8.2c.9 0 1.6-.7 1.6-1.6S7 6.1 6.1 6.1 4.5 6.8 4.5 7.7s.7 1.6 1.6 1.6Zm13.4 8.2v-3.9c0-2.3-1.2-3.4-2.9-3.4-1.3 0-1.9.7-2.3 1.2v-1H11.5v7h2.8v-3.9c0-1 .2-2 1.4-2s1.4 1.1 1.4 2v3.9h2.4Z",
            "M22 5.9c-.7.3-1.5.5-2.4.6.9-.5 1.5-1.3 1.8-2.3-.8.5-1.7.8-2.6 1-.8-.8-1.9-1.3-3.1-1.3-2.4 0-4.3 1.9-4.3 4.3 0 .3 0 .7.1 1C8 9 4.7 7.2 2.5 4.5c-.4.6-.6 1.4-.6 2.2 0 1.5.8 2.8 2 3.6-.7 0-1.4-.2-2-.5 0 2.1 1.5 3.9 3.5 4.3-.4.1-.7.2-1.1.2-.3 0-.5 0-.8-.1.5 1.7 2.1 2.9 3.9 3-1.4 1.1-3.2 1.7-5.2 1.7H1c1.8 1.2 4 1.9 6.3 1.9 7.5 0 11.7-6.3 11.7-11.7v-.5c.8-.6 1.5-1.3 2-2.2Z",
            "M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2Zm6.6 5.6c1.2 1.5 2 3.3 2.1 5.4h-3.5c0-2-.4-3.7-1-5 .9-.1 1.7-.2 2.4-.4Zm-3 7.8c.6-.7 1.2-1.6 1.5-2.5.7.4 1.4.6 2.1.7-.7 1.5-2 2.7-3.6 3.3v-1.5Zm0-8.8v.6c1.4-.4 2.7-1 3.6-1.7-.7.5-1.5 1-2.4 1.4l-1.2-.3Z",
          ].map((d) => (
            <a href="#" class="grid h-9 w-9 place-items-center rounded-full border border-ink-100 text-ink-700 transition hover:border-brand-300 hover:bg-brand-50 hover:text-brand-700">
              <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"><path d={d}/></svg>
            </a>
          ))}
        </div>
      </div>

      <div class="grid grid-cols-2 gap-8 sm:grid-cols-4 lg:col-span-8">
        {cols.map((c) => (
          <div>
            <p class="font-display text-sm font-semibold text-ink-950">{c.t}</p>
            <ul class="mt-4 space-y-2.5">
              {c.links.map((l) => (
                <li><a href={l.href} class="text-sm text-ink-700 transition hover:text-brand-700">{l.label}</a></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>

    <div class="mt-12 flex flex-wrap items-center justify-between gap-4 border-t border-ink-100 pt-6 text-xs text-ink-500">
      <p>© {year} Disart Energy. Todos los derechos reservados.</p>
      <p class="flex items-center gap-1.5">
        Hecho con
        <svg class="h-3.5 w-3.5 text-brand-600" viewBox="0 0 24 24" fill="currentColor"><path d="M12 21s-7-4.5-9.3-9.3C1.2 8.6 3.4 5 7 5c2 0 3.5 1 5 2.6C13.5 6 15 5 17 5c3.6 0 5.8 3.6 4.3 6.7C19 16.5 12 21 12 21Z"/></svg>
        para acelerar la transición a movilidad eléctrica.
      </p>
    </div>
  </div>
</footer>
