---
const number = (import.meta.env.PUBLIC_WHATSAPP_NUMBER ?? '').replace(/\D/g, '');
const message = import.meta.env.PUBLIC_WHATSAPP_MESSAGE
  ?? 'Hola Disart Energy 👋, vengo desde la web y quiero saber más sobre las electrolineras.';
const href = number
  ? `https://wa.me/${number}?text=${encodeURIComponent(message)}`
  : null;
---
{href && (
  <a
    href={href}
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Hablar por WhatsApp"
    class="group fixed bottom-5 right-5 z-40 flex items-center gap-2 rounded-full bg-[#25D366] px-4 py-3 text-sm font-semibold text-white shadow-glow transition hover:scale-105 hover:bg-[#128C4F] sm:bottom-7 sm:right-7"
  >
    <span class="relative grid h-6 w-6 place-items-center">
      <span class="absolute inset-0 animate-ping rounded-full bg-white/40"></span>
      <svg class="relative h-5 w-5" viewBox="0 0 32 32" fill="currentColor" aria-hidden>
        <path d="M16 .4C7.4.4.5 7.3.5 15.9c0 2.8.7 5.5 2.1 7.9L.4 31.6l8.1-2.1c2.3 1.3 4.9 1.9 7.5 1.9 8.6 0 15.5-7 15.5-15.5C31.5 7.3 24.6.4 16 .4Zm0 28.3c-2.4 0-4.7-.6-6.7-1.9l-.5-.3-4.8 1.3 1.3-4.7-.3-.5C3.5 20.6 2.7 18.3 2.7 16 2.7 8.6 8.7 2.6 16 2.6c3.6 0 7 1.4 9.5 3.9 2.5 2.5 3.9 5.9 3.9 9.4 0 7.4-6 13.4-13.4 13.4Zm7.4-9.9c-.4-.2-2.4-1.2-2.7-1.3-.4-.1-.6-.2-.9.2-.3.4-1 1.3-1.3 1.5-.2.3-.5.3-.9.1-.4-.2-1.7-.6-3.2-2-1.2-1-1.9-2.3-2.2-2.7-.2-.4 0-.6.2-.8.2-.2.4-.5.6-.7.2-.2.3-.4.4-.7.1-.3.1-.5 0-.7-.1-.2-.9-2.2-1.2-3-.3-.8-.7-.7-.9-.7h-.8c-.3 0-.7.1-1.1.5-.4.4-1.4 1.4-1.4 3.4 0 2 1.4 3.9 1.6 4.2.2.3 2.8 4.2 6.7 5.9.9.4 1.7.6 2.2.8.9.3 1.8.3 2.4.2.7-.1 2.4-1 2.7-1.9.3-.9.3-1.8.2-1.9-.1-.2-.4-.3-.7-.5Z"/>
      </svg>
    </span>
    <span class="hidden sm:inline">Escríbenos</span>
  </a>
)}
