---
import Logo from "./Logo.astro";
const links = [
  { href: "#solucion",  label: "Solución" },
  { href: "#franquicia", label: "Franquicia" },
  { href: "#tecnologia", label: "Tecnología" },
  { href: "#proceso",   label: "Proceso" },
  { href: "#faq",       label: "FAQ" },
];
---
<header class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto mt-4 max-w-6xl px-4">
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />

    <nav class="glass relative flex items-center justify-between rounded-3xl px-3 py-2 shadow-soft md:rounded-full">
      <Logo className="pl-2" />

      <ul class="hidden items-center gap-1 md:flex">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="rounded-full px-3 py-2 text-sm font-medium text-ink-700 transition hover:bg-brand-50 hover:text-brand-700"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <a
          href="#contacto"
          class="inline-flex items-center gap-1.5 rounded-full bg-ink-950 px-3.5 py-2 text-xs font-semibold text-white shadow-soft transition hover:bg-brand-700 sm:px-4 sm:text-sm"
        >
          <span class="sm:hidden">Franquicia</span>
          <span class="hidden sm:inline">Quiero una franquicia</span>
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <label
          for="nav-toggle"
          aria-label="Abrir menú"
          class="grid h-10 w-10 cursor-pointer place-items-center rounded-full border border-ink-100 bg-white/70 text-ink-900 transition hover:bg-brand-50 md:hidden"
        >
          <svg class="block h-5 w-5 peer-checked:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" data-icon="bars">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg class="hidden h-5 w-5 peer-checked:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" data-icon="x">
            <path d="M6 6l12 12M18 6l-12 12"/>
          </svg>
        </label>
      </div>
    </nav>

    <div class="pointer-events-none absolute inset-x-4 top-full mt-2 origin-top scale-y-95 rounded-2xl border border-ink-100 bg-white/95 p-2 opacity-0 shadow-soft backdrop-blur transition duration-200 peer-checked:pointer-events-auto peer-checked:scale-y-100 peer-checked:opacity-100 md:hidden">
      <ul class="flex flex-col">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="block rounded-xl px-4 py-3 text-sm font-semibold text-ink-800 transition hover:bg-brand-50 hover:text-brand-700"
              onclick="document.getElementById('nav-toggle').checked=false"
            >
              {l.label}
            </a>
          </li>
        ))}
        <li class="mt-1 border-t border-ink-100 pt-2">
          <a
            href="#contacto"
            class="block rounded-xl bg-ink-950 px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-brand-700"
            onclick="document.getElementById('nav-toggle').checked=false"
          >
            Quiero una franquicia
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  /* Toggle hamburger ↔ X via :checked sibling — needed because peer modifier
     applies to siblings but the icons are inside the label, not next to checkbox. */
  #nav-toggle:checked ~ nav [data-icon="bars"] { display: none; }
  #nav-toggle:checked ~ nav [data-icon="x"]    { display: block; }
</style>
