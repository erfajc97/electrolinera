---
import Logo from "./Logo.astro";

const solutions = [
  {
    href: "/electrolineras",
    icon: "bolt",
    title: "Electrolineras",
    desc: "Franquicia 720 kW llave en mano · ROI desde 8.6 meses.",
    featured: true,
  },
  {
    href: "/movilidad",
    icon: "car",
    title: "Movilidad eléctrica",
    desc: "Importamos vehículos e infraestructura de carga corporativa.",
  },
  {
    href: "/solar",
    icon: "sun",
    title: "Energía solar",
    desc: "Diseño, instalación y monitoreo de plantas solares.",
  },
];
const links = [
  { href: "/inversion", label: "Invertir", featured: true },
  { href: "/nosotros",  label: "Nosotros" },
  { href: "/#contacto", label: "Contacto" },
];
const icons: Record<string, string> = {
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3M5 5l2 2M17 17l2 2M5 19l2-2M17 7l2-2"/>',
  car: '<path d="M5 17h14"/><path d="M5 17a2 2 0 1 0 4 0M15 17a2 2 0 1 0 4 0"/><path d="M3 13l2-5h14l2 5v4H3v-4Z"/>',
  bolt: '<path d="M14 2 5 14h7l-2 8 9-12h-7l2-8Z"/>',
};
---
<header class="fixed inset-x-0 top-0 z-50">
  <div class="mx-auto mt-4 max-w-6xl px-4">
    <input type="checkbox" id="nav-toggle" class="peer sr-only" />

    <nav class="glass relative flex items-center justify-between rounded-3xl px-3 py-2 shadow-soft md:rounded-full">
      <Logo className="pl-2" />

      <ul class="hidden items-center gap-1 md:flex">
        <li class="group relative">
          <button
            type="button"
            class="inline-flex items-center gap-1.5 rounded-full px-3 py-2 text-sm font-medium text-ink-700 transition hover:bg-brand-50 hover:text-brand-700"
          >
            Soluciones
            <svg class="h-3 w-3 transition group-hover:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m6 9 6 6 6-6"/></svg>
          </button>
          <div class="invisible absolute left-1/2 top-full -translate-x-1/2 pt-2 opacity-0 transition group-hover:visible group-hover:opacity-100">
            <div class="w-[440px] rounded-2xl border border-ink-100 bg-white/95 p-2 shadow-soft backdrop-blur">
              <ul class="grid gap-1">
                {solutions.map((s) => (
                  <li>
                    <a href={s.href} class={`group/link flex items-start gap-3 rounded-xl px-3 py-3 transition ${s.featured ? "bg-linear-to-br from-brand-50 to-lime-glow/15 ring-1 ring-inset ring-brand-200 hover:from-brand-100 hover:to-lime-glow/25" : "hover:bg-brand-50"}`}>
                      <span class={`grid h-9 w-9 shrink-0 place-items-center rounded-lg text-white ${s.featured ? "bg-linear-to-br from-brand-600 to-brand-800 shadow-glow" : "bg-linear-to-br from-brand-500 to-brand-700"}`}>
                        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
                      </span>
                      <span class="flex-1">
                        <span class="flex items-center gap-1.5">
                          <span class="block font-display text-sm font-semibold text-ink-950 group-hover/link:text-brand-700">{s.title}</span>
                          {s.featured && <span class="rounded-full bg-brand-700 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white">Foco 2026</span>}
                        </span>
                        <span class="mt-0.5 block text-xs text-ink-700">{s.desc}</span>
                      </span>
                      <svg class="h-3.5 w-3.5 mt-1.5 text-ink-300 transition group-hover/link:translate-x-0.5 group-hover/link:text-brand-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </li>
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class={l.featured
                ? "inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-2 text-sm font-semibold text-brand-700 ring-1 ring-inset ring-brand-200 transition hover:bg-brand-100"
                : "rounded-full px-3 py-2 text-sm font-medium text-ink-700 transition hover:bg-brand-50 hover:text-brand-700"}
            >
              {l.featured && <span class="h-1.5 w-1.5 rounded-full bg-brand-600 animate-pulse-soft"></span>}
              {l.label}
            </a>
          </li>
        ))}
      </ul>

      <div class="flex items-center gap-2">
        <a
          href="/#contacto"
          class="inline-flex items-center gap-1.5 rounded-full bg-ink-950 px-3.5 py-2 text-xs font-semibold text-white shadow-soft transition hover:bg-brand-700 sm:px-4 sm:text-sm"
        >
          <span class="sm:hidden">Contacto</span>
          <span class="hidden sm:inline">Hablar con un asesor</span>
          <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </a>

        <label
          for="nav-toggle"
          aria-label="Abrir menú"
          class="grid h-10 w-10 cursor-pointer place-items-center rounded-full border border-ink-100 bg-white/70 text-ink-900 transition hover:bg-brand-50 md:hidden"
        >
          <svg class="block h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" data-icon="bars">
            <path d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg class="hidden h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" data-icon="x">
            <path d="M6 6l12 12M18 6l-12 12"/>
          </svg>
        </label>
      </div>
    </nav>

    <div class="pointer-events-none absolute inset-x-4 top-full mt-2 origin-top scale-y-95 rounded-2xl border border-ink-100 bg-white/95 p-2 opacity-0 shadow-soft backdrop-blur transition duration-200 peer-checked:pointer-events-auto peer-checked:scale-y-100 peer-checked:opacity-100 md:hidden">
      <p class="px-4 pt-2 pb-1 text-[10px] font-bold uppercase tracking-widest text-brand-700">Soluciones</p>
      <ul class="flex flex-col">
        {solutions.map((s) => (
          <li>
            <a
              href={s.href}
              class={`flex items-center gap-3 rounded-xl px-4 py-3 text-sm font-semibold transition ${s.featured ? "bg-brand-50 text-brand-700 ring-1 ring-inset ring-brand-200" : "text-ink-800 hover:bg-brand-50 hover:text-brand-700"}`}
              onclick="document.getElementById('nav-toggle').checked=false"
            >
              <span class={`grid h-7 w-7 shrink-0 place-items-center rounded-lg ${s.featured ? "bg-brand-700 text-white" : "bg-brand-50 text-brand-700"}`}>
                <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[s.icon]} />
              </span>
              <span class="flex-1">{s.title}</span>
              {s.featured && <span class="rounded-full bg-brand-700 px-1.5 py-0.5 text-[9px] font-bold uppercase tracking-wider text-white">Foco 2026</span>}
            </a>
          </li>
        ))}
      </ul>
      <p class="px-4 pt-3 pb-1 text-[10px] font-bold uppercase tracking-widest text-brand-700">Empresa</p>
      <ul class="flex flex-col">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class={`flex items-center gap-2 rounded-xl px-4 py-3 text-sm font-semibold transition ${l.featured ? "bg-brand-50 text-brand-700 ring-1 ring-inset ring-brand-200" : "text-ink-800 hover:bg-brand-50 hover:text-brand-700"}`}
              onclick="document.getElementById('nav-toggle').checked=false"
            >
              {l.featured && <span class="h-1.5 w-1.5 rounded-full bg-brand-600 animate-pulse-soft"></span>}
              {l.label}
            </a>
          </li>
        ))}
        <li class="mt-1 border-t border-ink-100 pt-2">
          <a
            href="/#contacto"
            class="block rounded-xl bg-ink-950 px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-brand-700"
            onclick="document.getElementById('nav-toggle').checked=false"
          >
            Hablar con un asesor
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<style>
  #nav-toggle:checked ~ nav [data-icon="bars"] { display: none; }
  #nav-toggle:checked ~ nav [data-icon="x"]    { display: block; }
</style>
